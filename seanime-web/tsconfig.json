{
  "compilerOptions": {
    "types": [
      "node",
      "@rsbuild/core/types"
    ],
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "*": [
        "./*"
      ],
      "@/*": [
        "./src/*"
      ],
      "next": [
        "./src/shims/next.ts"
      ],
      "next/navigation": [
        "./src/shims/next-navigation.ts"
      ],
      "next/link": [
        "./src/shims/next-link.ts"
      ],
      "next/image": [
        "./src/shims/next-image.ts"
      ],
      "next/font/google": [
        "./src/shims/next-font-google.ts"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "**/*.test.ts",
    "**/*.spec.ts"
  ],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
